# Proxmox VE
PVE_HOST=https://pve.example.com:8006
PVE_API_USER=root@pam
PVE_API_TOKEN_ID=lxc-swap!token
PVE_API_TOKEN_SECRET=your-secret-here

# Or use file-based secrets (Docker/K8s)
# PVE_API_TOKEN_ID_FILE=/run/secrets/pve_api_token_id
# PVE_API_TOKEN_SECRET_FILE=/run/secrets/pve_api_token_secret

# Containers
HOST_CT_ID=110
GUEST_CT_ID=128

# Auth
OWNER_NAMES=your-name
OWNER_GROUPS=proxmox-swap-owners
AUTH_MODE=header
AUTH_HEADER=X-Auth-Request-Name

# OIDC (required if AUTH_MODE=oidc)
# OIDC_ISSUER=https://accounts.google.com
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_CLIENT_ID_FILE=/run/secrets/oidc_client_id
# OIDC_CLIENT_SECRET_FILE=/run/secrets/oidc_client_secret
# SESSION_SECRET=your-session-secret
# SESSION_SECRET_FILE=/run/secrets/session_secret
# OIDC_PKCE=true
# OIDC_BASE_URI=https://swap.example.com
# OIDC_SCOPES=openid profile groups
# OIDC_USERNAME_CLAIM=preferred_username
# OIDC_GROUPS_CLAIM=groups

# Timeouts (seconds)
DEFAULT_TIMEOUT_SECONDS=7200
MAX_SECONDS=28800
WARNING_SECONDS=1800
FORCE_GRACE_SECONDS=600
WATCHDOG_INTERVAL_SECONDS=30

# PVE API (seconds)
PVE_API_TIMEOUT_SECONDS=30
PVE_RETRY_COUNT=3
PVE_RETRY_DELAY_SECONDS=1

# Container Switching (seconds)
CONTAINER_START_TIMEOUT_SECONDS=120
CONTAINER_STOP_TIMEOUT_SECONDS=120
SWITCH_COOLDOWN_SECONDS=1
POLL_INTERVAL_SECONDS=2

# Crash Recovery (seconds)
COURTESY_SESSION_SECONDS=1800

# State
STATE_FILE_PATH=/data/state.json

# Dev (set to "none" to skip authentication)
AUTH_MODE=none
